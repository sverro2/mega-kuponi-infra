map $host $backend {
    default http://127.0.0.1:{{ nginx_backend_port }};
    www.{{ nginx_admin_domain }} http://127.0.0.1:{{ nginx_admin_port }};
}

{% for domain in nginx_active_domains %}
# {{ domain }}
server {
    root /var/www;
    server_name {{ domain }} www.{{ domain }};

    limit_req_status 429;

    if ($host !~* ^www\.) {
        return 301 https://www.$host$request_uri;
    }

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    proxy_set_header X-Real-IP       $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header Host            $host;

    location /resources/ {
        expires 1y;
        add_header Cache-Control "public";
        try_files $uri $uri/ =404;
    }

    location /admin-api/ {
        proxy_pass http://127.0.0.1:{{ nginx_backend_port }};
    }

    location / {
        limit_req zone=general_limit burst=20 nodelay;
        proxy_pass $backend;
    }

{% if loop.first %}
    listen [::]:443 ssl ipv6only=on http2;
{% else %}
    listen [::]:443 ssl http2;
{% endif %}
    listen 443 ssl http2;
    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;
}
{% endfor %}

{% if nginx_disabled_domains %}
{% for domain in nginx_disabled_domains %}
# {{ domain }} - disabled
server {
    server_name {{ domain }} www.{{ domain }};

    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    return 410;
}
{% endfor %}
{% endif %}

# HTTP -> HTTPS redirect for all domains
server {
    server_name {% for domain in nginx_active_domains + nginx_disabled_domains %}{{ domain }} www.{{ domain }} {% endfor %};

    listen 80;
    listen [::]:80;

    if ($host !~* ^www\.) {
        return 301 https://www.$host$request_uri;
    }
    return 301 https://$host$request_uri;
}
